{
  "$schema": "https://railway.app/railway.schema.json",
  "services": {
    "researcher-backend": {
      "path": "researcher",
      "build": {
        "builder": "NIXPACKS",
        "buildCommand": "npm install && npm run build"
      },
      "deploy": {
        "startCommand": "npm run start",
        "healthcheckPath": "/api/health",
        "numReplicas": 1,
        "restartPolicyType": "ON_FAILURE"
      },
      "watchPaths": [
        "researcher/**",
        "!med-researcher/**"
      ]
    }
  }
}
