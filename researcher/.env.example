PORT=8000
FRONTEND_ORIGIN=http://localhost:3000
DATABASE_PATH=data/mars.db

OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini

SERPER_API_KEY=
TAVILY_API_KEY=
PERPLEXITY_API_KEY=
PERPLEXITY_MODEL=sonar-pro

# Optional. When set, MARS uses the real Parallel AI Search API for grounded
# web sources. Leave blank to fall back to an OpenAI-generated research map.
PARALLEL_API_KEY=
PARALLEL_MODE=advanced

# Optional. Max time (ms) any single search provider may take.
PROVIDER_TIMEOUT_MS=22000
# Optional. Max time (ms) any single OpenAI call may take.
OPENAI_TIMEOUT_MS=60000

# Optional shared secret. When set, every POST /api/research must send
# `Authorization: Bearer <token>`. Leave blank to disable auth (dev/local).
API_TOKEN=

# Cost/DoS guardrails for the research endpoint.
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=20
MAX_CONCURRENT_PIPELINES=4
